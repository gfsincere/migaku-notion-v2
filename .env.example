# Copy to .env and fill in your values. Same Notion section as v1; the
# Migaku section is shorter because v2 talks straight to Migaku's HTTP API
# (no MIGOKU_URL, no MIGOKU_API_KEY, no Go sidecar).

# --- Migaku --------------------------------------------------------------
# v2 derives Firebase auth tokens directly:
#   1. /v1/accounts:signInWithPassword (initial login, returns refresh_token)
#   2. /v1/token (every subsequent run, refreshes the short-lived id_token)
# Set email + password and v2 will derive the refresh_token on first run
# (or run `python -m migaku_notion login` once to do it explicitly).
MIGAKU_EMAIL=
MIGAKU_PASSWORD=

# Optional. After `login` (or first sync), v2 writes the long-lived refresh
# token here so future runs skip the password step.
MIGAKU_REFRESH_TOKEN=

# 32-hex device ID used as `?deviceId=` on /pull-sync and /push/enqueue.
# Auto-generated on first run (by `setup`, or by the first command that
# needs it via config.get_or_create_device_id()) and persisted back here.
# Migaku sees v2 as a stable "device" — same shape the browser extension
# and mobile apps register with. Do not edit unless you really mean to;
# changing it will look to Migaku like you've installed v2 on a new
# machine. To reset, delete the line below and re-run anything.
MIGAKU_DEVICE_ID=

# --- Notion --------------------------------------------------------------
# 1) Create an internal integration at https://www.notion.so/profile/integrations
# 2) Open the parent page in Notion -> ... -> Connections -> Connect to -> your integration
# 3) Paste the integration secret here:
NOTION_TOKEN=

# Page ID of the Migaku Vocab database (created by `setup`, or copied
# verbatim from your v1 .env — same DB schema in v2).
NOTION_DATABASE_ID=

# Optional. Override where v2 caches the downloaded Migaku dict +
# frequency .db files. Defaults to ~/.migaku-notion-v2/dicts/. Useful
# for testing or for keeping the cache on a different drive.
# MIGAKU_NOTION_DICTS_DIR=

# --- Sync options --------------------------------------------------------
SYNC_LANG=zh
# Statuses to include. Comma-separated. KNOWN, LEARNING, UNKNOWN, IGNORED, or ALL.
SYNC_STATUS=KNOWN,LEARNING
# How many words to consider for fail-rate enrichment (kept for parity with
# v1 even though v2 may compute fail-rate differently — see
# migaku_notion/migaku/pull.py::list_difficult_words).
SYNC_DIFFICULT_LIMIT=2000
